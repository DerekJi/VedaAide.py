# Copilot Chat Configuration
# Ensure VS Code pr-monitor-chat Extension is running
COPILOT_CHAT_URL=http://localhost:3456

# Monitor Configuration
PR_MONITOR_INTERVAL=1800        # 30 minutes in seconds
AUTO_COMMIT=true
AUTO_PUSH=true
VERIFY_BEFORE_COMMIT=true

# Trusted Users (comma-separated GitHub usernames)
# Only comments from these users will be processed
TRUSTED_USERS=DerekJi,derekj_youi

# Note: GitHub authentication uses gh CLI
# Ensure gh auth is configured: gh auth login
# No GITHUB_TOKEN needed!
