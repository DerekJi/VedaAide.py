# Skaffold 忽略文件（类似 .gitignore）
# 这些文件不会触发 Skaffold 重新构建

# Python 缓存
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache
**/*.egg-info

# 虚拟环境
.venv
venv/
env/

# 数据文件（大文件不触发重建）
data/raw/
data/evaluation/*.json
qdrant_storage/

# 测试和文档（不影响运行时）
tests/
docs/

# IDE 和工具
.vscode/
.idea/
*.swp
*.swo

# OS 文件
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# 日志
logs/
*.log
