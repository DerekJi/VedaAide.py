# GitHub Configuration
GITHUB_OWNER=DerekJi
GITHUB_REPO=VedaAide.py
GITHUB_TOKEN=ghp_your_github_token_here

# Copilot Chat API Configuration
# The PR Monitor Chat VS Code Extension exposes Copilot Chat via HTTP
# See: .vscode/extensions/pr-monitor-chat/
COPILOT_CHAT_HOST=localhost
COPILOT_CHAT_PORT=3456

# Monitor Configuration
PR_MONITOR_INTERVAL=1800        # Check every 30 minutes (in seconds)
AUTO_COMMIT=true                # Automatically commit changes
AUTO_PUSH=true                  # Automatically push to remote
VERIFY_BEFORE_COMMIT=true       # Run verification checks before committing

# Trusted Users (comma-separated GitHub usernames)
# Only comments from these users will be processed
TRUSTED_USERS=DerekJi,derekj_youi
