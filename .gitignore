# Ignore all the contents of the qdrant_storage folder (vector database data)
qdrant_storage/*

# But do not ignore the .gitkeep file, to keep the folder present
!qdrant_storage/.gitkeep

# Ignore all the contents of the langfuse_storage folder (LangFuse database data)
langfuse_storage/*

# But do not ignore the .gitkeep file, to keep the folder present
!langfuse_storage/.gitkeep

# Ignore all the contents of the .temp folder (temporary AI-generated files)
.temp/**

# But do not ignore the .gitkeep file, to keep the folder present
!.temp/README.md

# Ignore generated working datasets (Tier 2 data)
data/working_datasets/

# But do not ignore the .gitkeep file, to keep the folder present
!data/working_datasets/.gitkeep

# Ignore external downloaded datasets (Tier 3 data)
data/external_datasets/
!data/external_datasets/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.venv/
.env
.pytest_cache/
.coverage
htmlcov/