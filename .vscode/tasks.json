{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start PR Monitor (Copilot Chat)",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "cwd": "${workspaceFolder}/dev-tools/pr-monitor",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "line": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting PR Monitor.*$",
          "endsPattern": "^.*Sleeping for.*$"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Build PR Monitor",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "cwd": "${workspaceFolder}/dev-tools/pr-monitor",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Install PR Monitor Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "cwd": "${workspaceFolder}/dev-tools/pr-monitor",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Setup PR Monitor (.env from .env.example)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "cd ${workspaceFolder}/dev-tools/pr-monitor && test -f .env || (cp .env.example .env && echo 'Created .env from template. Configure TRUSTED_USERS if needed.')"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Lint PR Monitor Code",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "cwd": "${workspaceFolder}/dev-tools/pr-monitor",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
